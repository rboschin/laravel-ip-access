# Esempio di configurazione per modalità WHITELIST

# Modalità di accesso: whitelist o blacklist
IP_ACCESS_MODE=whitelist

# Lista di IP consentiti (separati da virgola)
# Supporta: IP esatti, wildcards (*), notazione CIDR
IP_WHITELIST=127.0.0.1,::1,192.168.1.*,10.0.0.0/8

# Messaggio personalizzato quando l'accesso viene negato (opzionale)
IP_ACCESS_FORBIDDEN_MESSAGE="Accesso negato. Il tuo IP non è autorizzato ad accedere al sistema."

# Abilita il supporto per proxy/load balancer (X-Forwarded-For) (opzionale, default: true)
IP_ACCESS_TRUST_PROXIES=true
